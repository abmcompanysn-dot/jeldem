{
  "version": 2,
  "routes": [
    { "src": "/app",    "dest": "/client_v2.html" },
    { "src": "/client", "dest": "/client_v2.html" },
    { "src": "/mobile", "dest": "/client_v2.html" },
    { "src": "/",       "dest": "/index.html"     }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "Cache-Control",          "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
